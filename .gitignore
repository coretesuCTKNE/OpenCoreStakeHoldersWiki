# Private Instance Data
# In a private instance downstream, these folders will contain real data
# For the public framework, we ignore everything in these directories except .gitkeep
/raw/*
!/raw/.gitkeep
!/raw/inbox/
/raw/inbox/*
!/raw/inbox/.gitkeep

/wiki/personas/*
!/wiki/personas/.gitkeep
/wiki/groups/*
!/wiki/groups/.gitkeep
