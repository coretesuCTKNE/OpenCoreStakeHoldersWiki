!/wiki/relationships/.gitkeep
/wiki/coalitions/*
!/wiki/coalitions/.gitkeep
/wiki/concepts/*
!/wiki/concepts/.gitkeep
/wiki/summaries/*
!/wiki/summaries/.gitkeep
/wiki/queries/*
!/wiki/queries/.gitkeep
/wiki/logs/*
!/wiki/logs/.gitkeep
/wiki/history/*
!/wiki/history/.gitkeep
/wiki/drafts/*
!/wiki/drafts/.gitkeep
/wiki/canary_baseline/*
!/wiki/canary_baseline/.gitkeep

/tests/golden_sources/*
!/tests/golden_sources/.gitkeep
/tests/golden_outputs/*
!/tests/golden_outputs/.gitkeep

